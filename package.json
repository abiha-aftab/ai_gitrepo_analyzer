{
  "name": "agents-anywhere-investigator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.3.2"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "node scripts/productionBuild.mjs",
    "build:render": "npm run build",
    "test": "npm run test --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

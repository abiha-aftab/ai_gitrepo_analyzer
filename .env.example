PORT=4000
# Local MongoDB:
MONGODB_URI=mongodb://127.0.0.1:27017/codebase-investigator
# Atlas / Render — paste full URI from Atlas → Connect → Drivers (host must look like cluster0.abcd.mongodb.net):
# If the password contains @ # / : etc., percent-encode them (e.g. @ → %40) or the parser will treat @ as the host separator and you get querySrv ENOTFOUND _mongodb._tcp.123 style errors.
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/codebase-investigator?retryWrites=true&w=majority

# Optional: OpenAI synthesis
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1

# Optional: AWS Bedrock synthesis (when set together, takes precedence over OpenAI).
# Prefer IAM/instance profile in prod — do not commit real keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
